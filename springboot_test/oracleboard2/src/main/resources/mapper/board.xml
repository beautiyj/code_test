<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.dao.BoardDao">

	<!-- com.example.demo.model.Board.java 경로를 앨리아스로 board 선언 -->
	<!-- 글작성 -->
	<insert id="insert" parameterType="board">
		INSERT INTO myboard2
		VALUES(myboard2_seq.nextval, #{writer},
		#{passwd}, #{subject},
		#{content}, 0, SYSDATE)
	</insert>

	<!-- 총 데이터 개수 -->
	<select id="count" resultType="int">
		SELECT COUNT(*) FROM myboard2
	</select>

	<!-- 글목록 (페이징) -->
	<select id="list" parameterType="int" resultType="board">
		SELECT * FROM (
		SELECT ROWNUM rnum, board.* FROM (
		SELECT * FROM myboard2 ORDER BY no
		DESC )
		board )
		WHERE rnum BETWEEN (#{page} - 1) * 10 + 1 AND #{page} *
		10
	</select>

	<!-- 조회수 증가 -->
	<update id="updatecount" parameterType="int">
		UPDATE myboard2
		SET
		readcount = readcount + 1
		WHERE no = #{no}
	</update>

	<!-- 상세정보 구하기 -->
	<select id="content" parameterType="int" resultType="board">
		SELECT *
		FROM myboard2 WHERE no = #{no}
	</select>

	<!-- 글수정 -->
	<update id="update" parameterType="board">
		UPDATE myboard2
		SET writer = #{writer}, subject = #{subject},
		content= #{content}, register = SYSDATE
		WHERE no = #{no}
	</update>

	<!-- 글삭제 -->
	<delete id="delete" parameterType="int">
		DELETE FROM myboard2 WHERE no = #{no}
	</delete>

</mapper>