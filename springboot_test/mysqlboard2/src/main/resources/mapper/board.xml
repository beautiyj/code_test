<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.dao.BoardDao">

	<!-- com.example.demo.model.Board.java 경로를 앨리아스로 board 선언 -->
	<!-- 글작성 -->
	<insert id="insert" parameterType="board">
		INSERT INTO myboard (writer,
		passwd, subject, content, readcount, register)
		VALUES (#{writer},
		#{passwd}, #{subject}, #{content}, 0, NOW())
	</insert>

	<!-- 글 개수 검색기능 추가용도로 코드 수정(동적메소드 where 추가,
	오라클3 버전과 mySQL 쿼리 다름. % 와일드카드로 연결한 오라클과 달리 CONCAT() 사용) -->
	<select id="count" parameterType="board" resultType="int">
		SELECT COUNT(*) FROM myboard
		<where>
			<if test="keyword != null and keyword != ''">
				${search} LIKE CONCAT('%', #{keyword}, '%')
			</if>
		</where>
	</select>

	<!-- 오라클과 달리 limit 연산자를 활용해서 달라진 코드 (MySql.ver) # limit 연산자: limit 추출데이터의 
		인덱스 번호, 추출 데이터 개수 -->
	<!-- 글목록 (페이징) : 검색 기능 추가하면서 파라미터타입 board로 수정 -->
	<select id="list" parameterType="board" resultType="board">
		SELECT * FROM
		myboard
		<where>
			<if test="keyword != null and keyword != ''">
				${search} LIKE CONCAT('%', #{keyword}, '%')
			</if>
		</where>
		ORDER BY no DESC
		LIMIT #{start}, 10
	</select>

	<!-- 조회수 증가 -->
	<update id="updatecount" parameterType="int">
		UPDATE myboard
		SET
		readcount = readcount + 1
		WHERE no = #{no}
	</update>

	<!-- 상세정보 구하기 -->
	<select id="content" parameterType="int" resultType="board">
		SELECT *
		FROM myboard WHERE no = #{no}
	</select>

	<!-- 글수정 -->
	<update id="update" parameterType="board">
		UPDATE myboard
		SET writer =
		#{writer}, subject = #{subject},
		content = #{content}, register = NOW()
		WHERE no = #{no}
	</update>

	<!-- 글삭제 -->
	<delete id="delete" parameterType="int">
		DELETE FROM myboard WHERE no =
		#{no}
	</delete>

</mapper>